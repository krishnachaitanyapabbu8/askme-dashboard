# AskMe Dashboard — Environment Variables
# Copy this file to .env and fill in the values

# ── API Mode (Live DB) ────────────────────────────────────────────────────────
# Set these to connect the dashboard directly to the Django backend.
# Leave VITE_API_URL empty to use the local Excel file instead.

VITE_API_URL=https://your-django-app.com
VITE_API_KEY=your-secret-api-key

# ── Django backend (.env in rerp-reporting-app) ───────────────────────────────
# The API key set here must match VITE_API_KEY above.
DASHBOARD_API_KEY=your-secret-api-key
